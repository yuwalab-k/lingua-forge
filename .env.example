# ============================================================
# ローカルLLM（Ollama）設定
# ============================================================

# ローカルLLMを使用するか（true / false）
# false にするとOllamaコンテナが起動せず、翻訳機能が無効になります
USE_LOCAL_LLM=true

# Docker Compose プロファイル
# USE_LOCAL_LLM=true の場合は local-llm を設定してください
# USE_LOCAL_LLM=false の場合はこの行をコメントアウトするか空にしてください
COMPOSE_PROFILES=local-llm

# Ollama接続先URL（USE_LOCAL_LLM=true の場合に使用）
OLLAMA_URL=http://ollama:11434

# 翻訳に使用するOllamaモデル名
OLLAMA_MODEL=mitmul/plamo-2-translate
